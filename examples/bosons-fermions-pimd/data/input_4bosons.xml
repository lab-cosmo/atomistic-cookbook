<simulation threading='False' verbosity='low'>

    <!-- Four BOSONS in a 3D harmonic trap.
         All four atom indices are listed in <bosons>, switching on bosonic
         exchange. The centroid-virial estimator (kinetic_cv) is NOT valid under
         exchange, so we record the thermodynamic estimator (kinetic_td) and the
         primitive/quantum virial (virial_fq) instead. -->

    <ffsocket mode='unix' name='driver'>
            <address>bf-4bosons</address>
    </ffsocket>

    <total_steps> 1000 </total_steps>

    <output prefix="data">
      <trajectory stride="100" filename="pos" cell_units="angstrom">positions{angstrom}</trajectory>
      <properties stride="1"> [ step, time{femtosecond}, conserved, temperature{kelvin},
            kinetic_td, potential, virial_fq ] </properties>
    </output>

    <prng>
      <seed> 18885 </seed>
    </prng>

    <system>

      <forces>
          <force forcefield="driver"></force>
      </forces>

      <initialize nbeads="32">
        <positions mode="manual" bead="0"> [-55, -81, -49, -83, -93, -38, 5, 22, -99, 30, -60, 15] </positions>
        <masses mode="manual"> ['1.0', '1.0', '1.0', '1.0'] </masses>
        <labels mode="manual"> ['E', 'E', 'E', 'E'] </labels>
        <cell>
         [ 2500, 0, 0, 0, 2500, 0, 0, 0, 2500 ]
        </cell>
        <velocities mode='thermal' units='kelvin'> 17.4 </velocities>
      </initialize>

      <normal_modes propagator='bab'>
          <nmts> 10 </nmts>
          <bosons> [0, 1, 2, 3] </bosons>
      </normal_modes>

      <ensemble>
         <temperature units="kelvin"> 17.4 </temperature>
      </ensemble>

      <motion mode="dynamics">
        <fixcom> False </fixcom>
        <dynamics mode="nvt">
         <timestep units="femtosecond"> 10 </timestep>
          <thermostat mode='pile_l'>
                <tau units='femtosecond'>100</tau>
          </thermostat>
        </dynamics>
      </motion>

    </system>

</simulation>
